<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.sellinghouses.salescontrol.module.appointment.mapper.AppointmentMapper">

    <resultMap id="AppointmentResultMap" type="com.sellinghouses.salescontrol.module.appointment.entity.Appointment">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="sales_user_id" property="salesUserId"/>
        <result column="building_id" property="buildingId"/>
        <result column="room_id" property="roomId"/>
        <result column="appointment_time" property="appointmentTime"/>
        <result column="contact_name" property="contactName"/>
        <result column="contact_phone" property="contactPhone"/>
        <result column="remark" property="remark"/>
        <result column="status" property="status"/>
        <result column="cancel_reason" property="cancelReason"/>
        <result column="create_time" property="createTime"/>
        <result column="update_time" property="updateTime"/>
        <result column="create_user" property="createUser"/>
        <result column="update_user" property="updateUser"/>
    </resultMap>

    <resultMap id="AppointmentQueryResultMap" type="com.sellinghouses.salescontrol.module.appointment.dto.AppointmentQueryDTO">
        <id column="id" property="id"/>
        <result column="user_id" property="userId"/>
        <result column="sales_user_id" property="salesUserId"/>
        <result column="sales_name" property="salesName"/>
        <result column="building_id" property="buildingId"/>
        <result column="building_name" property="buildingName"/>
        <result column="room_id" property="roomId"/>
        <result column="room_no" property="roomNo"/>
        <result column="appointment_time" property="appointmentTime"/>
        <result column="contact_name" property="contactName"/>
        <result column="contact_phone" property="contactPhone"/>
        <result column="remark" property="remark"/>
        <result column="status" property="status"/>
        <result column="cancel_reason" property="cancelReason"/>
        <result column="create_time" property="createTime"/>
    </resultMap>

    <sql id="AppointmentColumns">
        id,
        user_id,
        sales_user_id,
        building_id,
        room_id,
        appointment_time,
        contact_name,
        contact_phone,
        remark,
        status,
        cancel_reason,
        create_time,
        update_time,
        create_user,
        update_user
    </sql>

    <insert id="insert" parameterType="com.sellinghouses.salescontrol.module.appointment.entity.Appointment" useGeneratedKeys="true" keyProperty="id">
        INSERT INTO appointment (
            user_id,
            sales_user_id,
            building_id,
            room_id,
            appointment_time,
            contact_name,
            contact_phone,
            remark,
            status,
            create_user,
            update_user
        ) VALUES (
            #{userId},
            #{salesUserId},
            #{buildingId},
            #{roomId},
            #{appointmentTime},
            #{contactName},
            #{contactPhone},
            #{remark},
            #{status},
            #{createUser},
            #{updateUser}
        )
    </insert>

    <update id="cancel">
        UPDATE appointment
        SET status = 4,
            cancel_reason = #{cancelReason},
            update_user = #{updateUser},
            update_time = NOW()
        WHERE id = #{id}
    </update>

    <update id="updateStatus">
        UPDATE appointment
        SET status = #{status},
        <if test="salesUserId != null">
            sales_user_id = #{salesUserId},
        </if>
            update_user = #{updateUser},
            update_time = NOW()
        WHERE id = #{id}
    </update>

    <select id="selectById" resultMap="AppointmentResultMap">
        SELECT
        <include refid="AppointmentColumns"/>
        FROM appointment
        WHERE id = #{id}
        LIMIT 1
    </select>

    <select id="selectUserPage" resultMap="AppointmentResultMap">
        SELECT
        <include refid="AppointmentColumns"/>
        FROM appointment
        WHERE user_id = #{userId}
        <if test="query.status != null">
          AND status = #{query.status}
        </if>
        ORDER BY appointment_time DESC, id DESC
    </select>

    <select id="selectSalesPage" resultMap="AppointmentResultMap">
        SELECT
        <include refid="AppointmentColumns"/>
        FROM appointment
        WHERE sales_user_id = #{salesUserId}
        <if test="query.status != null">
          AND status = #{query.status}
        </if>
        ORDER BY appointment_time DESC, id DESC
    </select>

    <select id="selectAdminPage" resultMap="AppointmentQueryResultMap">
        SELECT
            a.id,
            a.user_id,
            a.sales_user_id,
            COALESCE(s.real_name, s.username) AS sales_name,
            a.building_id,
            b.name AS building_name,
            a.room_id,
            r.room_no,
            a.appointment_time,
            a.contact_name,
            a.contact_phone,
            a.remark,
            a.status,
            a.cancel_reason,
            a.create_time
        FROM appointment a
        LEFT JOIN building b ON a.building_id = b.id AND b.deleted = 0
        LEFT JOIN room r ON a.room_id = r.id
        LEFT JOIN `user` s ON a.sales_user_id = s.id
        WHERE 1 = 1
        <if test="estateId != null">
          AND a.building_id = #{estateId}
        </if>
        <if test="salesUserId != null">
          AND a.sales_user_id = #{salesUserId}
        </if>
        <if test="status != null">
          AND a.status = #{status}
        </if>
        ORDER BY a.appointment_time DESC, a.id DESC
    </select>
</mapper>
